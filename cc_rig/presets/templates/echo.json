{
  "name": "echo",
  "language": "go",
  "framework": "echo",
  "project_type": "api",
  "tool_commands": {
    "test": "go test ./...",
    "lint": "golangci-lint run",
    "format": "goimports -w .",
    "typecheck": "go vet ./...",
    "build": "go build ./cmd/server"
  },
  "source_dir": ".",
  "test_dir": ".",
  "recommended_skills": [
    {
