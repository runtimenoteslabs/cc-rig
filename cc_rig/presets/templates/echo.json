      "source": "trailofbits/skills",
      "install": "npx skills add trailofbits/skills --skill property-based-testing",
      "description": "Multi-language property testing (Go/rapid)"
    },
    {
      "name": "static-analysis",
      "sdlc_phase": "security",
      "source": "trailofbits/skills",
      "install": "npx skills add trailofbits/skills --skill static-analysis",
      "description": "CodeQL, Semgrep, SARIF parsing"
    },
    {
      "name": "supabase-postgres-best-practices",
      "sdlc_phase": "database",
      "source": "supabase/agent-skills",
      "install": "npx skills add supabase/agent-skills --skill supabase-postgres-best-practices",
      "description": "PostgreSQL best practices with Supabase"
    },
    {
      "name": "planetscale-postgresql",
      "sdlc_phase": "database",
      "source": "planetscale/database-skills",
      "install": "npx skills add planetscale/database-skills --skill planetscale-postgresql",
      "description": "Postgres MVCC, VACUUM, WAL tuning, replication"
    },
    {
      "name": "dockerfile-generator",
      "sdlc_phase": "devops",
      "source": "akin-ozer/cc-devops-skills",
      "install": "npx skills add akin-ozer/cc-devops-skills --skill dockerfile-generator",
