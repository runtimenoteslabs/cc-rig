{
  "name": "spec-driven",
  "version": 2,
  "description": "Plan-first. Spec workflow + worktrees.",
  "source": "cc-rig + mattpocock/skills + obra/superpowers",
  "source_url": "",
  "process_skills": [
    "write-a-prd",
    "prd-to-issues",
    "writing-plans",
    "executing-plans"
  ],
  "agents": [
    "code-reviewer",
    "test-writer",
    "explorer",
    "architect",
    "refactorer",
    "pr-reviewer",
    "implementer",
    "pm-spec"
  ],
  "commands": [
    "fix-issue",
    "review",
    "test",
    "plan",
    "research",
    "learn",
    "assumptions",
    "remember",
    "refactor",
    "spec-create",
    "spec-execute",
    "techdebt",
    "worktree"
  ],
  "hooks": [
    "format",
    "lint",
    "typecheck",
    "block-rm-rf",
    "block-env",
    "block-main",
    "session-context",
    "stop-validator",
    "memory-precompact",
    "push-review"
  ],
  "features": {
    "memory": true,
    "spec_workflow": true,
    "gtd": false,
    "worktrees": true
  },
  "permission_mode": "permissive"
}
