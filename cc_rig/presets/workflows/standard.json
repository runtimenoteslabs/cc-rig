{
  "name": "standard",
  "description": "Solid defaults for most projects. Memory + lessons.",
  "agents": [
    "code-reviewer",
    "test-writer",
    "explorer",
    "architect",
    "refactorer"
  ],
  "commands": [
    "fix-issue",
    "review",
    "test",
    "plan",
    "research",
    "learn",
    "assumptions",
    "remember",
    "refactor"
  ],
  "hooks": [
    "format",
    "lint",
    "typecheck",
    "block-rm-rf",
    "block-env",
    "block-main",
    "session-context",
    "stop-validator",
    "memory-precompact"
  ],
  "features": {
    "memory": true,
    "spec_workflow": false,
    "gtd": false,
    "worktrees": false
  },
  "permission_mode": "permissive"
}
