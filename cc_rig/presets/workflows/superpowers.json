{
  "name": "superpowers",
  "version": 2,
  "description": "Obra's full SDLC skill suite. Maximum rigor, all agents.",
  "source": "obra/superpowers",
  "source_url": "https://github.com/obra/superpowers",
  "process_skills": [
    "brainstorming",
    "writing-plans",
    "executing-plans",
    "test-driven-development",
    "systematic-debugging",
    "requesting-code-review",
    "receiving-code-review",
    "verification-before-completion",
    "subagent-driven-development",
    "using-git-worktrees",
    "finishing-a-development-branch"
  ],
  "agents": [
    "code-reviewer",
    "test-writer",
    "explorer",
    "architect",
    "refactorer",
    "pr-reviewer",
    "implementer",
    "pm-spec",
    "security-auditor",
    "doc-writer",
    "techdebt-hunter",
    "db-reader"
  ],
  "commands": [
    "fix-issue",
    "review",
    "test",
    "plan",
    "research",
    "learn",
    "assumptions",
    "remember",
    "refactor",
    "spec-create",
    "spec-execute",
    "techdebt",
    "security",
    "document",
    "optimize",
    "gtd-capture",
    "gtd-process",
    "daily-plan",
    "worktree"
  ],
  "hooks": [
    "format",
    "lint",
    "typecheck",
    "block-rm-rf",
    "block-env",
    "block-main",
    "session-context",
    "stop-validator",
    "memory-precompact",
    "push-review",
