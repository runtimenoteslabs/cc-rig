{
  "name": "gstack",
  "version": 2,
  "description": "Garry Tan's cognitive gears workflow. Plan, Review, Ship.",
  "source": "garrytan/gstack",
  "source_url": "https://github.com/garrytan/gstack",
  "process_skills": [
    "plan-ceo-review",
    "plan-eng-review",
    "plan-design-review",
    "gstack-review",
    "ship",
    "document-release"
  ],
  "agents": [
    "code-reviewer",
    "test-writer",
    "explorer",
    "architect",
    "pr-reviewer"
  ],
  "commands": [
    "fix-issue",
    "review",
    "test",
    "plan",
    "research",
    "learn",
    "assumptions",
    "remember",
    "refactor"
  ],
  "hooks": [
    "format",
    "lint",
    "typecheck",
    "block-rm-rf",
    "block-env",
    "block-main",
    "session-context",
    "stop-validator",
    "memory-precompact",
    "push-review"
  ],
  "features": {
    "memory": true,
    "spec_workflow": false,
    "gtd": false,
    "worktrees": true,
    "github_actions": true
  },
  "permission_mode": "permissive"
}
